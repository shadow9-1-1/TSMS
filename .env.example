# =========================================
# Render / Production (fast live demo)
# =========================================
FLASK_CONFIG=production
SECRET_KEY=replace-with-a-long-random-secret

# Auto-create tables on first boot and seed a demo admin account
AUTO_CREATE_DB=1
DEMO_ADMIN_NAME=Demo Admin
DEMO_ADMIN_EMAIL=demo@example.com
DEMO_ADMIN_USERNAME=demo_admin
DEMO_ADMIN_PASSWORD=ChangeMe123!

# Optional managed database (if omitted, production falls back to SQLite demo DB)
# DATABASE_URL=postgresql://username:password@host:5432/database


# =========================================
# Local Development (optional)
# =========================================
# FLASK_CONFIG=development
# FLASK_DEBUG=1
# DEV_DATABASE_URL=sqlite:///data-dev.sqlite
# TEST_DATABASE_URL=sqlite:///:memory:
